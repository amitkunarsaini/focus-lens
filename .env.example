# ---------------------------------------------------------------------------
# Database (PostgreSQL). The docker-compose file provisions these defaults.
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://focuslens:focuslens@localhost:5432/focuslens?schema=public"

# ---------------------------------------------------------------------------
# NextAuth
# Generate a secret with: openssl rand -base64 32
# ---------------------------------------------------------------------------
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-me-with-a-long-random-string"

# Google OAuth (optional — credentials provider works without it for dev)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---------------------------------------------------------------------------
# AI layer (optional). FocusLens computes all core analytics WITHOUT this.
# If unset, the platform falls back to a deterministic narrative engine.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=""
FOCUSLENS_AI_MODEL="claude-opus-4-8"

# Public base URL the browser extension posts events to.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
