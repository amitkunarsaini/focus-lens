// FocusLens — Attention Intelligence Platform
// Prisma schema. Datasource: PostgreSQL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────────────────────────────────────────────────────────────────────────
// Enums
// ───────────────────────────────────────────────────────────────────────────

enum Category {
  Work
  Learning
  Development
  Research
  Documentation
  Communication
  News
  Entertainment
  SocialMedia
  Shopping
  Uncategorized
}

/// Coarse productivity bucket each category maps to. Used by the scoring engine.
enum Productivity {
  Productive
  Neutral
  Distracting
}

enum UserMode {
  LIVE
  DEMO
}

enum GoalType {
  LEARN_TOPIC
  CATEGORY_TIME
  LIMIT_CATEGORY
  DEEP_WORK
}

enum GoalPeriod {
  DAILY
  WEEKLY
}

/// Whether the user wants to hit AT_LEAST the target or stay AT_MOST under it.
enum GoalDirection {
  AT_LEAST
  AT_MOST
}

enum InsightType {
  DAILY_SUMMARY
  WEEKLY_REPORT
  PATTERN
  ATTENTION_LEAK
  RECOMMENDATION
  RISK
}

enum InsightSource {
  DETERMINISTIC
  AI
}

// ───────────────────────────────────────────────────────────────────────────
// Auth (NextAuth) + User
// ───────────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String? // for credentials provider (hashed)

  // FocusLens
  mode        UserMode @default(LIVE)
  timezone    String   @default("UTC")
  onboarded   Boolean  @default(false)
  ingestToken String   @unique @default(cuid()) // extension auth token

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts          Account[]
  sessions          Session[]
  browsingEvents    BrowsingEvent[]
  focusSessions     FocusSession[]
  attentionLeaks    AttentionLeak[]
  dailyAnalytics    DailyAnalytics[]
  productivityScores ProductivityScore[]
  goals             Goal[]
  insights          Insight[]
  categoryOverrides CategoryOverride[]
}

/// A user-defined classification override for a domain. Applied on top of the
/// rule-based classifier so users can correct or personalise categories.
model CategoryOverride {
  id        String   @id @default(cuid())
  userId    String
  domain    String
  category  Category
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, domain])
  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ───────────────────────────────────────────────────────────────────────────
// Raw activity
// ───────────────────────────────────────────────────────────────────────────

/// One contiguous span of attention on a single URL. Emitted by the extension
/// when focus moves away from a page (tab switch, navigation, blur, idle).
model BrowsingEvent {
  id        String   @id @default(cuid())
  userId    String
  url       String   @db.Text
  title     String   @db.Text
  domain    String
  category  Category @default(Uncategorized)

  startTime DateTime
  endTime   DateTime
  duration  Int // seconds of active attention

  tabId     Int?
  windowId  Int?
  /// What ended this span: "tab_switch" | "navigation" | "window_blur" | "idle" | "tab_close"
  endReason String?
  /// Domain the user came from immediately before this span (for flow analysis).
  fromDomain String?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startTime])
  @@index([userId, domain])
  @@index([userId, category])
}

// ───────────────────────────────────────────────────────────────────────────
// Derived intelligence
// ───────────────────────────────────────────────────────────────────────────

model FocusSession {
  id              String   @id @default(cuid())
  userId          String
  startTime       DateTime
  endTime         DateTime
  duration        Int // seconds
  primaryCategory Category
  primaryDomain   String
  productivityScore Int // 0–100
  interruptions   Int      @default(0)
  eventCount      Int      @default(0)
  /// Distinct domains visited within the session, in order.
  domains         String[]

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startTime])
}

/// A productive run that got broken up by distracting detours.
model AttentionLeak {
  id              String   @id @default(cuid())
  userId          String
  startTime       DateTime
  endTime         DateTime
  primaryCategory Category
  primaryDomain   String
  interruptions   Int // count of distracting detours
  lostSeconds     Int // measured time spent on detours
  recoverySeconds Int // estimated refocus cost (~23s/switch heuristic)
  /// The distracting domains that broke focus, most-frequent first.
  triggers        String[]

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startTime])
}

/// One row per user per day — the precomputed rollup the dashboard reads.
model DailyAnalytics {
  id     String   @id @default(cuid())
  userId String
  date   DateTime @db.Date

  totalSeconds       Int @default(0)
  productiveSeconds  Int @default(0)
  neutralSeconds     Int @default(0)
  distractingSeconds Int @default(0)
  focusSeconds       Int @default(0) // time inside focus sessions
  deepWorkSeconds    Int @default(0) // focus sessions >= 45 min

  contextSwitches   Int @default(0)
  attentionLeaks    Int @default(0)
  idleSeconds       Int @default(0)

  productivityScore  Int @default(0) // 0–100
  focusScore         Int @default(0) // 0–100
  contextSwitchScore Int @default(0) // 0–100 (higher = fewer switches)

  topCategory       Category @default(Uncategorized)
  peakFocusStart    DateTime?
  peakFocusEnd      DateTime?

  /// { [Category]: seconds }
  categoryBreakdown Json @default("{}")
  /// { [domain]: seconds } top domains
  domainBreakdown   Json @default("{}")
  /// 24-length array of { productive, neutral, distracting } seconds per hour
  hourlyBreakdown   Json @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

/// Explainable productivity score with its component contributions.
model ProductivityScore {
  id     String   @id @default(cuid())
  userId String
  date   DateTime @db.Date

  score Int // 0–100

  focusComponent    Int // contribution from deep-focus time
  switchingComponent Int // penalty/credit from context switching
  idleComponent     Int
  categoryComponent Int // credit from productive-category time
  goalComponent     Int // credit from goal alignment

  explanation String @db.Text

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model Goal {
  id          String        @id @default(cuid())
  userId      String
  title       String
  description String?       @db.Text
  type        GoalType
  period      GoalPeriod    @default(DAILY)
  direction   GoalDirection @default(AT_LEAST)

  /// For CATEGORY_TIME / LIMIT_CATEGORY goals.
  targetCategory Category?
  /// For LEARN_TOPIC goals — matched against page titles/domains.
  keywords       String[]
  /// Target attention in seconds for the period.
  targetSeconds  Int

  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, active])
}

model Insight {
  id       String        @id @default(cuid())
  userId   String
  date     DateTime      @db.Date
  type     InsightType
  source   InsightSource @default(DETERMINISTIC)
  severity Int           @default(0) // 0 info, 1 notice, 2 warning

  title String
  body  String @db.Text
  /// Structured payload backing the narrative (numbers, domains, deltas).
  data  Json   @default("{}")

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([userId, type])
}
